    {
      "parameters": {
        "jsCode": "// Classifica o tipo de alerta e separa clientes por grupo\n// Configure CLIENT_GROUP_REGEX com os nomes dos seus clientes prioritários\nconst CLIENT_GROUP_REGEX = /{{CLIENT_GROUP_REGEX}}/i; // Ex: /ClienteA|ClienteB|ClienteC/i\n\nreturn $input.all().map(item => {\n  const title = item.json.title || '';\n  const clientName = item.json.client?.name || '';\n  \n  let tipo_alerta = 'desconhecido';\n  let grupo_cliente = 'outros';\n  \n  // Classificação do tipo de alerta\n  if (/Link de Internet - Inoperante/i.test(title)) {\n    tipo_alerta = 'link_inoperante';\n  } else if (/Internet Down/i.test(title)) {\n    tipo_alerta = 'internet_down';\n  }\n  \n  // Classificação do grupo de cliente\n  if (CLIENT_GROUP_REGEX.test(clientName)) {\n    grupo_cliente = 'grupo_prioritario';\n  }\n  \n  return {\n    json: {\n      ...item.json,\n      tipo_alerta,\n      grupo_cliente\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4240, 2752],
      "id": "6f3795fd-7bbf-4896-bc4e-586fe5469faa",
      "name": "Classificar Tipo e Cliente"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [4464, 2752],
      "id": "c2514774-7784-4646-8450-145951ec08fb",
      "name": "Loop Tickets"
