    {
      "parameters": {
        "jsCode": "// Gera mensagem de restabelecimento de Link\nconst item = $input.first().json;\nconst timestamp = new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\n\nconst mensagem = `✅ *MONITORAMENTO: LINK RESTABELECIDO* ✅\\n\\n` +\n  `🏢 *Empresa:* ${item.client?.name || 'N/A'}\\n` +\n  `🎫 *Ticket:* #${item.ticket_number}\\n` +\n  `🌐 *Status:* ONLINE\\n\\n` +\n  `🚀 A conexão foi normalizada. O ticket foi identificado como finalizado no TiFlux.\\n\\n` +\n  `🕒 *Restabelecido em:* ${timestamp}`;\n\nconst clientName = item.client?.name || 'N/A';\n\n// Configure aqui os destinatários do WhatsApp\nconst equipe = [\n  { nome: '{{MEMBER_1_NAME}}', numero: '{{MEMBER_1_WHATSAPP}}' }\n  // { nome: '{{MEMBER_2_NAME}}', numero: '{{MEMBER_2_WHATSAPP}}' }\n];\n\nreturn equipe.map(d => ({\n  json: {\n    numero: d.numero,\n    nome: d.nome,\n    mensagem,\n    ticket_number: item.ticket_number,\n    client_name: clientName\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4800, 3232],
      "id": "7f4d4ec5-81b4-4dee-bd6c-ea41b76ce530",
      "name": "Msg Restabelecido (Link)"
    },
    {
      "parameters": {
        "jsCode": "// Gera mensagem de restabelecimento Ubiquiti/WAN\nconst item = $input.first().json;\nconst timestamp = new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nconst title = item.title || '';\n\n// Extrai site do título\nconst titleMatch = title.match(/(?:FW:\\s*)?(.+?):\\s*WAN\\d+/i);\nconst site = titleMatch ? titleMatch[1].trim() : (item.client?.name || 'N/A');\n\nconst mensagem = `✅ *UBIQUITI - INTERNET RESTABELECIDA* ✅\\n\\n` +\n  `🏢 *Empresa:* ${item.client?.name || 'N/A'}\\n` +\n  `📍 *Site:* ${site}\\n` +\n  `🎫 *Ticket:* #${item.ticket_number}\\n` +\n  `🌐 *Status:* O link voltou a operar normalmente.\\n\\n` +\n  `🚀 A conexão foi normalizada e o tráfego não está mais em failover.\\n\\n` +\n  `🕒 *Restabelecido em:* ${timestamp}`;\n\nconst clientName = item.client?.name || 'N/A';\n\n// Configure aqui os destinatários do WhatsApp\nconst equipe = [\n  { nome: '{{MEMBER_1_NAME}}', numero: '{{MEMBER_1_WHATSAPP}}' }\n  // { nome: '{{MEMBER_2_NAME}}', numero: '{{MEMBER_2_WHATSAPP}}' }\n];\n\nreturn equipe.map(d => ({\n  json: {\n    numero: d.numero,\n    nome: d.nome,\n    mensagem,\n    ticket_number: item.ticket_number,\n    client_name: clientName\n  }\n}));"
      },
