    {
      "parameters": {
        "jsCode": "// Determina a tabela correta baseado no tipo de alerta\n// Tabela A = Link Inoperante (clientes do grupo prioritário)\n// Tabela B = Internet Down (demais clientes)\nconst item = $input.first().json;\nconst tipo = item.tipo_alerta;\nconst grupo = item.grupo_cliente;\n\n// Substitua pelos IDs reais das suas tabelas no Baserow\nlet tableId = '{{BASEROW_TABLE_LINK_ID}}';\nlet ticketField = '{{BASEROW_FIELD_TICKET_LINK}}';\n\nif (tipo === 'internet_down') {\n  tableId = '{{BASEROW_TABLE_WAN_ID}}';\n  ticketField = '{{BASEROW_FIELD_TICKET_WAN}}';\n} else if (tipo === 'link_inoperante' && grupo === 'grupo_prioritario') {\n  tableId = '{{BASEROW_TABLE_LINK_ID}}';\n  ticketField = '{{BASEROW_FIELD_TICKET_LINK}}';\n} else {\n  // link_inoperante de clientes fora do grupo prioritário: pular\n  return [{ json: { ...item, _skip: true } }];\n}\n\nreturn [{\n  json: {\n    ...item,\n    _tableId: tableId,\n    _ticketField: ticketField,\n    _skip: false\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4688, 2752],
      "id": "02bd13e2-ad66-48a4-8022-dcba8509da88",
