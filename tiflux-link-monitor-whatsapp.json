    {
      "parameters": {
        "jsCode": "// Formata dados para notificação via WhatsApp\n// Configure a lista de destinatários abaixo\nconst item = $input.first().json;\nconst parentData = $('Resolver Tabela Baserow').first().json;\nconst tipo = parentData.tipo_alerta;\nconst description = item.description || '';\nconst title = item.title || parentData.title || '';\nconst CLIENT_GROUP_REGEX = /{{CLIENT_GROUP_REGEX}}/i;\n\n// Limpa HTML\nconst text = description.replace(/<[^>]*>?/gm, ' ').replace(/&nbsp;/g, ' ').replace(/\\s+/g, ' ').trim();\n\nlet mensagem = '';\nlet dados = {};\n\nif (tipo === 'link_inoperante') {\n  // === FORMATO ZABBIX ===\n  const hostMatch = text.match(/Host:\\s*(.*?)(?=\\s*Problema)/i);\n  const problemaMatch = text.match(/Problema:\\s*(.*?)(?=\\s*Data:)/i);\n  const dataMatch = text.match(/Data:\\s*([\\d.]+)/i);\n  const horaMatch = text.match(/Hora:\\s*([\\d:]+)/i);\n  const itemMatch = text.match(/Item:\\s*(.*?)(?=\\s*Status)/i);\n  const valorMatch = text.match(/Valor:\\s*(.*?)(?=\\s*IP:|\\s*Severidade:)/i);\n  const severityMatch = text.match(/Severidade:\\s*(.*)/i);\n  \n  dados = {\n    host: hostMatch ? hostMatch[1].trim() : 'N/A',\n    problema: problemaMatch ? problemaMatch[1].trim() : 'N/A',\n    item_monitorado: itemMatch ? itemMatch[1].trim() : 'N/A',\n    data_ocorrencia: dataMatch ? dataMatch[1].trim() : 'N/A',\n    hora_ocorrencia: horaMatch ? horaMatch[1].trim() : 'N/A',\n    valor: valorMatch ? valorMatch[1].trim() : 'N/A',\n    severidade: severityMatch ? severityMatch[1].trim() : 'Disaster'\n  };\n  \n  mensagem = `🚨 *ALERTA DE INCIDENTE - ZABBIX* 🚨\\n\\n` +\n    `🏢 *Empresa:* ${item.client?.name || 'N/A'}\\n` +\n    `🖥️ *Host:* ${dados.host}\\n` +\n    `⚠️ *Problema:* ${dados.problema}\\n` +\n    `🔧 *Item:* ${dados.item_monitorado}\\n` +\n    `📊 *Valor:* ${dados.valor}\\n` +\n    `🔴 *Severidade:* ${dados.severidade}\\n` +\n    `📅 *Data:* ${dados.data_ocorrencia} às ${dados.hora_ocorrencia}\\n` +\n    `🔗 *Ticket:* #${item.ticket_number}`;\n    \n} else if (tipo === 'internet_down') {\n  // === FORMATO UBIQUITI (Email HTML) ===\n  const titleMatch = title.match(/(?:FW:\\s*)?(.+?):\\s*WAN\\d+\\s*Internet Down/i);\n  const deviceMatch = text.match(/Device Name:\\s*(.*?)(?=\\s*Time:)/i);\n  const connectionMatch = text.match(/Internet connection\\s*(.*?)\\s*on port\\s*(\\d+)\\s*is\\s*down/i);\n  const timeMatch = text.match(/Time:\\s*(.*?)(?=\\s*Go To|$)/i);\n  const wanMatch = title.match(/(WAN\\d+)\\s*Internet Down/i);\n  \n  const site = deviceMatch ? deviceMatch[1].trim() : (titleMatch ? titleMatch[1].trim() : 'Site Desconhecido');\n  const wan = wanMatch ? wanMatch[1] : 'WAN';\n  const provedor = connectionMatch ? connectionMatch[1].trim() : wan;\n  const porta = connectionMatch ? connectionMatch[2] : 'N/A';\n  const horario = timeMatch ? timeMatch[1].trim() : new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\n  \n  dados = { site, wan, provedor, porta, horario };\n  \n  mensagem = `🛰️ *UBIQUITI - ALERTA DE INTERNET DOWN* 🛰️\\n\\n` +\n    `🏢 *Empresa:* ${item.client?.name || 'N/A'}\\n` +\n    `📍 *Site:* ${dados.site}\\n` +\n    `🔌 *Interface:* ${dados.provedor}\\n` +\n    `🔢 *Porta:* ${dados.porta}\\n` +\n    `📉 *Status:* ${dados.wan} DOWN\\n` +\n    `🎫 *Ticket:* #${item.ticket_number}\\n\\n` +\n    `⚡ A conexão ${dados.provedor} caiu. Verifique o link e o equipamento.\\n\\n` +\n    `🕒 *Detectado em:* ${dados.horario}`;\n}\n\nconst clientName = item.client?.name || 'N/A';\n\n// Configure aqui os destinatários do WhatsApp\n// Use o formato internacional sem '+' (ex: 5511999999999)\nconst equipe = [\n  { nome: '{{MEMBER_1_NAME}}', numero: '{{MEMBER_1_WHATSAPP}}' }\n  // Adicione mais membros conforme necessário:\n  // { nome: '{{MEMBER_2_NAME}}', numero: '{{MEMBER_2_WHATSAPP}}' }\n];\n\nreturn equipe.map(d => ({\n  json: {\n    numero: d.numero,\n    nome: d.nome,\n    mensagem,\n    tipo_alerta: tipo,\n    ticket_number: item.ticket_number,\n    client_name: clientName,\n    ...dados\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [5360, 2640],
